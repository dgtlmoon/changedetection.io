# Core service — local dev environment.

# App-runtime role (RLS applies).
CORE_DATABASE_URL=postgresql+asyncpg://app_runtime:app_runtime_dev_password@localhost:5432/onchange

# Admin role (BYPASSRLS). Used by Alembic.
CORE_DATABASE_ADMIN_URL=postgresql+asyncpg://identity_admin:identity_admin_dev_password@localhost:5432/onchange

CORE_LOG_LEVEL=INFO
CORE_ENVIRONMENT=development
