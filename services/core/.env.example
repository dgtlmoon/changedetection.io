# Core service — local dev environment.

# App-runtime role (RLS applies).
CORE_DATABASE_URL=postgresql+asyncpg://app_runtime:app_runtime_dev_password@localhost:5432/onchange

# Admin role (BYPASSRLS). Used by Alembic.
CORE_DATABASE_ADMIN_URL=postgresql+asyncpg://identity_admin:identity_admin_dev_password@localhost:5432/onchange

# --- Object storage -----------------------------------------------------------
# "local" (default) writes to the filesystem under
# CORE_OBJECT_STORE_LOCAL_ROOT. "s3" requires aioboto3 and the S3_*
# settings below.
CORE_OBJECT_STORE_BACKEND=local
CORE_OBJECT_STORE_LOCAL_ROOT=./var/object-store

# Required only when CORE_OBJECT_STORE_BACKEND=s3. Works with AWS S3,
# Cloudflare R2, MinIO, etc. Leave the standard AWS env vars
# (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY) set OR provide the
# CORE_-prefixed pair below.
CORE_OBJECT_STORE_S3_BUCKET=
CORE_OBJECT_STORE_S3_REGION=
CORE_OBJECT_STORE_S3_ENDPOINT_URL=
CORE_OBJECT_STORE_S3_ACCESS_KEY_ID=
CORE_OBJECT_STORE_S3_SECRET_ACCESS_KEY=

CORE_LOG_LEVEL=INFO
CORE_ENVIRONMENT=development
