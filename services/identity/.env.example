# Identity service — local dev environment
# Copy to .env for local development.

# --- Database -----------------------------------------------------------------
# App-runtime role (respects Row-Level Security).
IDENTITY_DATABASE_URL=postgresql+asyncpg://app_runtime:app_runtime_dev_password@localhost:5432/onchange

# Admin role (BYPASSRLS) used only for cross-org lookups in auth code paths.
IDENTITY_DATABASE_ADMIN_URL=postgresql+asyncpg://identity_admin:identity_admin_dev_password@localhost:5432/onchange

# --- Redis --------------------------------------------------------------------
IDENTITY_REDIS_URL=redis://localhost:6379/0

# --- Tenancy ------------------------------------------------------------------
# Root domain for subdomain-based tenant resolution.
# Request host `acme.change.sairo.app` resolves to org slug `acme`.
IDENTITY_ROOT_DOMAIN=change.sairo.app

# --- Secrets ------------------------------------------------------------------
# 32+ random bytes, base64. Generate: openssl rand -base64 48
# Used to sign short-lived access JWTs (Phase 2).
IDENTITY_SECRET_KEY=change-me-in-production-48-bytes-of-random-data-goes-here

# --- Runtime ------------------------------------------------------------------
IDENTITY_LOG_LEVEL=INFO
IDENTITY_ENVIRONMENT=development
