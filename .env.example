# ============================================================================
# onChange by Sairo — environment variable reference
# ----------------------------------------------------------------------------
# Copy this file to `.env` for local development, or paste the values you need
# into the Coolify "Environment Variables" tab for a Coolify deployment.
#
# See `COOLIFY.md` for a full walkthrough of where to obtain each secret.
# ============================================================================


# --- CORE NETWORKING --------------------------------------------------------
# The Flask listen host (0.0.0.0 = all interfaces; "::" = dual-stack).
LISTEN_HOST=0.0.0.0
# Internal port the app listens on. Coolify routes its domain to this port.
PORT=5000
# Public URL embedded in notifications, RSS, and the API. On Coolify this is
# set automatically from SERVICE_URL_CHANGEDETECTION_5000; only set manually
# if you are not on Coolify.
BASE_URL=
# Trust X-Forwarded-* headers from a reverse proxy (set to 1 behind Coolify /
# Traefik / nginx).
USE_X_SETTINGS=1
# Optional Flask SERVER_NAME override (rarely needed).
FLASK_SERVER_NAME=
# Enable gzip/brotli response compression inside Flask.
FLASK_ENABLE_COMPRESSION=false
# Comma-separated CORS origins; "*" allows any. Tighten for production.
CORS_ALLOWED_ORIGINS=*


# --- TLS (only if terminating TLS in-app; Coolify usually handles this) ------
SSL_CERT_FILE=
SSL_PRIVKEY_FILE=


# --- SECURITY / PRIVACY ------------------------------------------------------
# Salted password hash that locks the admin UI. Generate from within the app
# (Settings -> General -> Password), or let Coolify fill it from
# SERVICE_PASSWORD_64_CHANGEDETECTION.
SALTED_PASS=
# Hide the Referer header when fetching watched pages.
HIDE_REFERER=true
# Disable the upstream telemetry / version-check ping.
DISABLE_VERSION_CHECK=true
# Allow file:// URIs as watch targets. DANGEROUS — only enable on a trusted
# single-tenant instance.
ALLOW_FILE_URI=false
# Allow fetching IANA-restricted addresses (private/loopback/metadata). SSRF
# risk; keep false unless you know why you're changing it.
ALLOW_IANA_RESTRICTED_ADDRESSES=false
# Block "simple" hostnames (no dot). Leave false.
BLOCK_SIMPLEHOSTS=false
# Regex of URL schemes the app will fetch. Default covers http/https/file/etc.
SAFE_PROTOCOL_REGEX=
# Disable the "no proxy" option in the Watch editor.
ENABLE_NO_PROXY_OPTION=true


# --- WORKERS / PERFORMANCE ---------------------------------------------------
# Concurrent page fetchers.
FETCH_WORKERS=10
# Concurrent notification dispatchers.
NOTIFICATION_WORKERS=1
# Absolute minimum seconds between rechecks (guardrail; 0 disables).
MINIMUM_SECONDS_RECHECK_TIME=3
# Per-worker job/runtime caps before the worker restarts itself.
WORKER_MAX_JOBS=10
WORKER_MAX_RUNTIME=3600
# Hard cap on watched pages per instance (empty = unlimited).
PAGE_WATCH_LIMIT=


# --- LOGGING / LOCALE --------------------------------------------------------
# TRACE, DEBUG, INFO, SUCCESS, WARNING, ERROR, CRITICAL
LOGGER_LEVEL=INFO
# IANA timezone name; used by the scheduler. See
# https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC
LC_ALL=en_US.UTF-8


# --- SOCKET.IO (realtime UI updates) -----------------------------------------
# `threading` (default) or `gevent`.
SOCKETIO_MODE=threading
SOCKETIO_CORS_ORIGINS=
SOCKETIO_LOGGING=false


# --- CHROME / JAVASCRIPT FETCHERS -------------------------------------------
# Uncomment ONE of these to enable JavaScript rendering. Point at the
# corresponding browser container (see docker-compose.coolify.yml).
PLAYWRIGHT_DRIVER_URL=
PLAYWRIGHT_BROWSER_TYPE=chromium
PLAYWRIGHT_SERVICE_WORKERS=allow
# Legacy Selenium driver URL (older and less featured than Playwright).
WEBDRIVER_URL=
WEBDRIVER_DELAY_BEFORE_CONTENT_READY=5
WEBDRIVER_CONNECTION_TIMEOUT=90
WEBDRIVER_PAGELOAD_TIMEOUT=45
# Extra Chrome flags (one per line inside the value).
CHROME_OPTIONS=
# Aggressive Chrome fetch mode (Puppeteer-only).
FAST_PUPPETEER_CHROME_FETCHER=false
PUPPETEER_MAX_PROCESSING_TIMEOUT_SECONDS=180
# Browser-step recording cache lifetime.
BROWSER_STEPS_MAX_AGE_SECONDS=600
BROWSERSTEPS_MINUTES_KEEPALIVE=10


# --- OUTBOUND HTTP / PROXIES -------------------------------------------------
# Plain-requests proxy settings (SOCKS5 supported via socks5h://).
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=
# Requests-fetcher retry tuning.
REQUESTS_RETRY_MAX_COUNT=6
REQUESTS_RETRY_STATUS_FORCELIST=429,502,503,504
CHARDET_MIN_CONFIDENCE=0.9


# --- SCREENSHOTS / IMAGE DIFF -----------------------------------------------
# Max screenshot height in pixels (higher = more RAM).
SCREENSHOT_MAX_HEIGHT=16000
SCREENSHOT_QUALITY=72
SCREENSHOT_CHUNK_HEIGHT=10000
# Image SSIM diff tuning (only relevant if image_ssim_diff is enabled).
MAX_DIFF_HEIGHT=8000
MAX_DIFF_WIDTH=900
OPENCV_SUBPROCESS_TIMEOUT=20
OPENCV_BLUR_SIGMA=3.0
ENABLE_TEMPLATE_TRACKING=false


# --- CONTENT PROCESSING ------------------------------------------------------
# Disabled processors (comma-separated). image_ssim_diff is off by default
# because OpenCV is optional on ARM.
DISABLED_PROCESSORS=image_ssim_diff
# Allow risky JQ expressions in JSON watches.
JQ_ALLOW_RISKY_EXPRESSIONS=false
# Comma-separated XPath functions to block (empty = default blocklist).
XPATH_BLOCKED_FUNCTIONS=
# Jinja2 render-output guardrail.
JINJA2_MAX_RETURN_PAYLOAD_SIZE_KB=10240
# PDF-to-HTML tool invoked when watching PDFs.
PDF_TO_HTML_TOOL=pdftohtml
# Brotli snapshot compression.
SNAPSHOT_BROTLI_COMPRESSION_THRESHOLD=20480
DISABLE_BROTLI_TEXT_SNAPSHOT=false
# Force fsync on every datastore write (slower, safer on unreliable storage).
FORCE_FSYNC_DATA_IS_CRITICAL=false


# --- BACKUPS / RESTORE -------------------------------------------------------
MAX_NUMBER_BACKUPS=100
MAX_RESTORE_UPLOAD_MB=256
MAX_RESTORE_DECOMPRESSED_MB=1024


# --- NOTIFICATIONS ----------------------------------------------------------
# Optional prefix inserted in front of every notification mail button URL.
NOTIFICATION_MAIL_BUTTON_PREFIX=
# Default for the "Send a notification when a filter fails" setting.
FILTER_FAILURE_NOTIFICATION_SEND_DEFAULT=true


# --- AI-ASSISTED FILTER BUILDER ---------------------------------------------
# Required ONLY if you want the "describe what to monitor in English" feature.
# Create a key at https://console.anthropic.com/settings/keys
# Cost: pay-per-call to Anthropic. Leave blank to disable the feature.
ANTHROPIC_API_KEY=
AI_FILTER_MAX_HTML_CHARS=20000


# --- PLUGINS (optional) -----------------------------------------------------
# Space-separated pip packages installed by docker-entrypoint.sh at container
# start. See https://changedetection.io/plugins
EXTRA_PACKAGES=
