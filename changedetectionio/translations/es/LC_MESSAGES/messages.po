msgstr "operacional"

#: changedetectionio/blueprint/settings/templates/settings.html
msgid "workers"
msgstr "trabajadores"

#: changedetectionio/blueprint/settings/templates/settings.html
msgid "actively processing"
msgstr "procesando activamente"

#: changedetectionio/blueprint/settings/templates/settings.html
